extends layout.pug

block content
  section.detail-panel
    header
      hgroup
        h1= `${problem.pid} - ${problem.title}`
        p.page-lead Read the statement, pick a supported language, and submit a solution below.
      p
        each language, index in problem.allowLanguages
          span.status-chip(class=index === 0 ? 'ac' : '')= language
          if index !== problem.allowLanguages.length - 1
            |  
    .grid
      article
        header
          h2 Statement
        pre.mono-block= problem.statementMarkdown
      article
        header
          h2 Submit code
          p.soft-note Use the same workflow you would expect on a standard OJ page.
        form(method="post" action="/submissions")
          input(type="hidden" name="pid" value=problem.pid)
          label(for="language") Language
          select(name="language" id="language")
            each language in problem.allowLanguages
              option(value=language)= language
          label(for="sourceCode") Source code
          textarea(name="sourceCode" id="sourceCode" placeholder="Write your solution here")
          .grid
            button(type="submit") Submit code
            a(href="/problems" role="button" class="secondary") Back to problem list
