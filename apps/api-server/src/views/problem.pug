//- 题目详情页：先阅读题面，再提交代码。
extends layout.pug
include mixins/assets.pug

block content
  section.detail-panel
    header
      hgroup
        h1= `${problem.pid} - ${problem.title}`
        .problem-meta-row
          span.problem-meta-label= "支持语言"
          each language, index in problem.allowLanguages
            span.status-chip(class=index === 0 ? 'ac' : '')= language
            if index !== problem.allowLanguages.length - 1
              = ' '
      .page-actions
        a(href="#submit" role="button")= "提交代码"
        a(href="/problems" role="button" class="secondary")= "返回题目列表"
    .problem-layout
      article.panel-card
        header
          h2= "题面"
          .panel-header-actions
            button#copyStatementButton(type="button" class="secondary")= "复制题面"
        .panel-body.statement-block.markdown-body
          != problem.statementHtml
        script#problemStatementMarkdown(type="application/json")!= scriptJson(problem.statementMarkdown)
      article#submit.panel-card.problem-submit-card
        header
          h2= "提交代码"
          p.soft-note= "选择语言，粘贴或编写代码，然后提交评测。"
        .panel-body
          p#submissionAlert.form-alert(role="alert" hidden=!formError)= formError || ''
          form#submissionForm(method="post" action='/submissions')
            input(type="hidden" name="pid" value=problem.pid)
            input(type="hidden" name="sourceCode" id="sourceCode" value=(formValues && formValues.sourceCode) || '')
            label(for="language")= "语言"
            select(name="language" id="language" required disabled=problem.allowLanguages.length === 0)
              each language in problem.allowLanguages
                option(value=language selected=formValues && formValues.language === language)= language
            p.soft-note= "源代码"
            .editor-shell#sourceCodeEditor(data-initial-language=problem.allowLanguages[0])
            .form-actions
              button(type="submit" disabled=problem.allowLanguages.length === 0)= "提交代码"
              a(href='/problems' role="button" class="secondary")= "返回题目列表"

block pageScripts
  +pageScript('/assets/axios.min.js')
  +pageScript('/assets/notyf.min.js')
  +pageScript('/assets/notify.js')
  +pageScript('/assets/form-utils.js')
  +pageScript('/assets/problem-statement.js')
  +pageScript('/assets/editor/problem-editor.js', 'module')
