//- 比赛详情页：当前先做结构壳，后续可以继续挂规则、题目和榜单。
extends layout.pug

block content
  section.detail-panel
    header
      hgroup
        h1= contest.title
        p.page-lead= contest.description
    .detail-grid
      .detail-main
        article.panel-card
          header
            h2= "关于这个页面"
          .panel-body
            p= "这是第一阶段的比赛页面外壳。现在先把 OJ 的比赛导航结构补齐，之后再继续加入规则、榜单和更多比赛行为。"
      .detail-sidebar
        article.panel-card
          header
            h3= "状态"
          .panel-body
            .info-stack
              .info-item
                strong= "状态"
                p
                  span.status-chip.pending= formatContestStatusLabel(contest.status)
              .info-item
                strong= "开始时间"
                p= contest.startAtText
              .info-item
                strong= "结束时间"
                p= contest.endAtText
