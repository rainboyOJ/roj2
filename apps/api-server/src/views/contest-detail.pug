//- 比赛详情页：当前先做结构壳，后续可以继续挂规则、题目和榜单。
extends layout.pug

block content
  section.detail-panel
    header
      hgroup
        h1= contest.title
        p.page-lead= contest.description
    .detail-grid
      .detail-main
        article.panel-card
          header
            h2= t('contest.aboutTitle')
          .panel-body
            p= t('contest.aboutBody')
      .detail-sidebar
        article.panel-card
          header
            h3= t('contest.status')
          .panel-body
            .info-stack
              .info-item
                strong= t('contest.status')
                p
                  span.status-chip.pending= localizeContestStatus(contest.status)
              .info-item
                strong= t('contest.start')
                p= contest.startAtText
              .info-item
                strong= t('contest.end')
                p= contest.endAtText
