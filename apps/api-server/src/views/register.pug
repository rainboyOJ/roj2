//- 注册页：当前面向学生账号注册，注册后默认待审核。
extends layout.pug
include mixins/assets.pug

block content
  section.auth-panel
    header
      hgroup
        h1= "学生注册"
        p.page-lead= "创建一个供班级使用的基础账号，必要时等待管理员审核。"
    article.panel-card.form-card
      .panel-body
        p#registerAlert.form-alert(role="alert" hidden)
        form#registerForm(method="post" action='/register')
          .form-grid
            div
              label(for="username")= "用户名"
              input#username(type="text" name="username" placeholder="student_01" required minlength="3" maxlength="24" pattern="^[a-z0-9_]{3,24}$" autocomplete="username")
              small.soft-note 只能使用小写字母、数字、下划线，长度 3-24。
            div
              label(for="name")= "姓名"
              input#name(type="text" name="name" placeholder="你的姓名" required autocomplete="name")
            fieldset.form-block
              legend= "性别"
              .choice-row
                label.choice-chip
                  input(type="radio" name="gender" value="male" checked required)
                  span 男
                label.choice-chip
                  input(type="radio" name="gender" value="female")
                  span 女
            div
              label(for="grade")= "年级"
              select#grade(name="grade" required)
                each grade in grades
                  option(value=grade.name)= grade.name
            div
              label(for="className")= "班级"
              select#className(name="className" required)
                each classRecord in classes
                  option(value=classRecord.name)= classRecord.name
            div
              label(for="password")= "密码"
              input#password(type="password" name="password" placeholder="至少 8 个字符" required minlength="8" autocomplete="new-password")
              small.soft-note 密码至少 8 个字符。
          .form-actions
            button(type="submit")= "注册"
            a(href='/login' role="button" class="secondary")= "返回登录"

block pageScripts
  +formScripts('register.js', true)
