//- 管理员提交列表页：查看全站所有提交。
extends layout.pug
include mixins/pagination.pug
include mixins/status.pug

block content
  - const currentPageSuffix = pagination && pagination.page > 1 ? `?page=${pagination.page}` : ''
  section.list-panel
    header
      hgroup
        h1= "提交管理"
        p.page-lead= "用标准列表视图查看所有提交的评测活动。"
      .page-actions
        a(href="/admin/submissions/cleanup-deleted-users" role="button" class="secondary")= "清理已删除用户提交"
        a(href=`/admin/submissions${currentPageSuffix}` role="button" class="secondary")= "刷新"
    if cleanupResult
      p.form-alert(role="status")= `已清理 ${cleanupResult.submissionCount} 条提交记录，${cleanupResult.progressCount} 条做题进度。`
    if submissions.length
      .table-shell
        table.data-table
          thead
            tr
              th= "提交号"
              th= "用户"
              th= "题目"
              th= "语言"
              th= "分数"
              th= "状态"
              th= "评测机"
              th= "结果"
              th= "操作"
          tbody
            each submission in submissions
              tr
                td.table-code
                  a(href=`/submissions/${submission.publicId}`)= submission.publicId
                td= submission.displayName ? `${submission.displayName} (${submission.username})` : submission.username
                td
                  a(href=`/problem/${submission.pid}`)= submission.problemLabel
                td.table-code= submission.language
                td.table-code= submission.score
                td= formatStatusLabel(submission.status)
                td= submission.judgeStatus ? formatJudgeStatusLabel(submission.judgeStatus) : '-'
                td
                  +verdictChip(submission.verdict)
                td
                  a(href=`/submissions/${submission.publicId}`)= "查看详情"
      +paginationBar('/admin/submissions', pagination, '提交管理分页')
    else
      article
        p= "还没有提交记录。"
