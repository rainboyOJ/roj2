//- 管理员提交列表页：查看全站所有提交。
extends layout.pug
include mixins/pagination.pug

block content
  section.list-panel
    header
      hgroup
        h1= "提交管理"
        p.page-lead= "用标准列表视图查看所有提交的评测活动。"
    if submissions.length
      .table-shell
        table.data-table
          thead
            tr
              th= "提交号"
              th= "用户"
              th= "题目"
              th= "语言"
              th= "分数"
              th= "状态"
              th= "评测机"
              th= "结果"
              th= "操作"
          tbody
            each submission in submissions
              tr
                td.table-code
                  a(href=`/submissions/${submission.publicId}`)= submission.publicId
                td= submission.displayName ? `${submission.displayName} (${submission.username})` : submission.username
                td
                  a(href=`/problem/${submission.pid}`)= submission.problemLabel
                td.table-code= submission.language
                td.table-code= submission.score
                td= formatStatusLabel(submission.status)
                td= submission.judgeStatus ? formatJudgeStatusLabel(submission.judgeStatus) : '-'
                td
                  if submission.verdict === 'AC'
                    span.status-chip.ac= formatVerdictLabel(submission.verdict)
                  else if submission.verdict === 'PENDING'
                    span.status-chip.pending= formatVerdictLabel(submission.verdict)
                  else
                    span.status-chip.failed= formatVerdictLabel(submission.verdict)
                td
                  a(href=`/submissions/${submission.publicId}`)= "查看详情"
      +paginationBar('/admin/submissions', pagination, '提交管理分页')
    else
      article
        p= "还没有提交记录。"
