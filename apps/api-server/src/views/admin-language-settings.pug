extends layout.pug
include mixins/assets.pug

block content
  section.auth-panel
    header
      hgroup
        h1= "语言设置"
        p.page-lead= "控制全站哪些编程语言对用户可见且允许提交。"
    article.panel-card.form-card
      .panel-body
        p#adminLanguageAlert.form-alert(role="alert" hidden)
        form#adminLanguageForm(method="post" action='/admin/settings/languages')
          fieldset
            legend= "启用语言"
            label
              input(
                type="checkbox"
                name="enabledLanguages"
                value="cpp"
                checked=settings.enabledLanguages.includes('cpp')
              )
              | C++
            label
              input(
                type="checkbox"
                name="enabledLanguages"
                value="python"
                checked=settings.enabledLanguages.includes('python')
              )
              | Python
          .form-actions
            button(type="submit")= "保存设置"
            a(href='/admin' role="button" class="secondary")= "返回管理后台"

block pageScripts
  +formScripts('admin-language-settings.js', false)
