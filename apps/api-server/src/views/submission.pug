extends layout.pug

block content
  section.detail-panel
    header
      hgroup
        h1= `Submission ${submission.id}`
        p.page-lead This page refreshes automatically while judging is still in progress.
    .metric-grid
      div.metric-card
        span.soft-note Status
        strong= submission.status
      div.metric-card
        span.soft-note Verdict
        strong= submission.verdict
      div.metric-card
        span.soft-note Judge status
        strong= submission.judgeStatus || 'Waiting'
    if submission.message
      article
        header
          h2 Judge message
        pre.mono-block= submission.message
    footer
      .page-actions
        a(href="/submissions" role="button" class="secondary") Back to submission list
        a(href="/problems" role="button" class="contrast") Open problem list
    script.
      const terminal = ['FINISHED', 'FAILED'];
      if (!terminal.includes('#{submission.status}')) {
        setTimeout(() => {
          window.location.reload();
        }, 2000);
      }
