//- 单条提交详情页：展示当前 OJ 状态、judge 状态和 judge message。
extends layout.pug

block content
  section.detail-panel#submissionDetail(
    data-submission-id=submission.publicId
    data-terminal=(submission.status === 'FINISHED' || submission.status === 'FAILED' ? 'true' : 'false')
  )
    header
      hgroup
        h1= `${t('submission.title')} ${submission.publicId}`
        p.page-lead= t('submission.lead')
    .detail-grid
      .detail-main
        article.panel-card
          header
            h2= t('submission.info')
          .panel-body
            ul.compact-list
              li
                strong= t('submission.user')
                span= submission.displayName ? `${submission.displayName} (${submission.username})` : submission.username
              li
                strong= t('submission.problem')
                span
                  a(href=urlWithLang(`/problem/${submission.pid}`))= submission.problemLabel
              li
                strong= t('submission.language')
                span.table-code= submission.language
        .metric-grid
          div.metric-card
            span.soft-note= t('submission.status')
            strong#submissionStatus= localizeStatus(submission.status)
          div.metric-card
            span.soft-note= t('submission.verdict')
            strong#submissionVerdict= localizeVerdict(submission.verdict)
          div.metric-card
            span.soft-note= t('submission.score')
            strong#submissionScore= submission.score
          div.metric-card
            span.soft-note= t('submission.judgeStatus')
            strong#submissionJudgeStatus= submission.judgeStatus ? localizeJudgeStatus(submission.judgeStatus) : t('submission.waiting')
        article.panel-card#submissionMessagePanel(hidden=!submission.message)
          header
            h2= t('submission.judgeMessage')
          .panel-body.statement-block
            pre.mono-block#submissionMessage= submission.message || ''
        article.panel-card
          header
            h2= t('submission.sourceCode')
          .panel-body.statement-block
            pre.mono-block= submission.sourceCode
        article.panel-card
          header
            h2= t('submission.caseResults')
            p= t('submission.caseResultsLead')
          .panel-body#submissionCaseResults
            if submission.caseResults && submission.caseResults.length
              .table-shell
                table.data-table
                  thead
                    tr
                      th= t('submission.caseSeq')
                      th= t('submission.caseVerdict')
                      th= t('submission.caseCpu')
                      th= t('submission.caseReal')
                      th= t('submission.caseMemory')
                      th= t('submission.caseExit')
                      th= t('submission.caseSignal')
                      th= t('submission.caseError')
                  tbody
                    each item in submission.caseResults
                      tr
                        td.table-code= `#${item.seq_id}`
                        td
                          - const verdictClass = item.verdict === 'AC' ? 'ac' : (item.verdict === 'PENDING' ? 'pending' : 'failed')
                          span(class=`status-chip ${verdictClass}`)= localizeVerdict(item.verdict)
                        td.table-code= `${item.cpu_time_ms} ms`
                        td.table-code= `${item.real_time_ms} ms`
                        td.table-code= `${item.memory_kb} KB`
                        td.table-code= item.exit_code
                        td.table-code= item.signal
                        td.table-code= item.error_code
            else
              p.soft-note= t('submission.noCaseResults')
      .detail-sidebar
        article.panel-card
          header
            h3= t('submissions.action')
          .panel-body
            .form-actions
              a(href=urlWithLang('/submissions') role="button" class="secondary")= t('submission.backToSubmissions')
              a(href=urlWithLang('/problems') role="button" class="contrast")= t('submission.openProblems')
    script(src=assetUrl('/assets/submission-detail.js'))
