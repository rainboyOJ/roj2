//- 单条提交详情页：展示当前 OJ 状态、judge 状态和 judge message。
extends layout.pug
include mixins/assets.pug
include mixins/status.pug

block content
  section.detail-panel#submissionDetail(
    data-submission-id=submission.publicId
    data-terminal=(submission.status === 'FINISHED' || submission.status === 'FAILED' ? 'true' : 'false')
  )
    header
      hgroup
        h1= `${"提交"} ${submission.publicId}`
        p.page-lead= "评测尚未结束时，这个页面会自动刷新。"
    .detail-grid
      .detail-main
        article.panel-card
          header
            h2= "提交信息"
          .panel-body
            ul.compact-list
              li
                strong= "提交用户"
                span= submission.displayName ? `${submission.displayName} (${submission.username})` : submission.username
              li
                strong= "题目"
                span
                  a(href=`/problem/${submission.pid}`)= submission.problemLabel
              li
                strong= "语言"
                span.table-code= submission.language
        .metric-grid
          div.metric-card
            span.soft-note= "状态"
            strong#submissionStatus= formatStatusLabel(submission.status)
          div.metric-card
            span.soft-note= "结果"
            strong#submissionVerdict= formatVerdictLabel(submission.verdict)
          div.metric-card
            span.soft-note= "分数"
            strong#submissionScore= submission.score
          div.metric-card
            span.soft-note= "评测机状态"
            strong#submissionJudgeStatus= submission.judgeStatus ? formatJudgeStatusLabel(submission.judgeStatus) : "等待中"
        p#submissionPendingHint.soft-note(hidden=submission.status === 'FINISHED' || submission.status === 'FAILED')
          | 系统已经收到提交，正在等待评测机返回结果；本页会自动更新。
        article.panel-card#submissionMessagePanel(hidden=!submission.message)
          header
            h2= "评测信息"
          .panel-body.statement-block
            pre.mono-block#submissionMessage= submission.message || ''
        article.panel-card
          header
            h2= "提交代码"
          .panel-body.statement-block
            if submission.canViewSourceCode
              pre.mono-block= submission.sourceCode
            else
              p.soft-note= "无权限查看该提交源码。"
        article.panel-card
          header
            h2= "测试点结果"
            p= "逐个测试点查看判定、耗时、内存和退出信息。"
          .panel-body#submissionCaseResults
            if submission.caseResults && submission.caseResults.length
              .table-shell
                table.data-table
                  thead
                    tr
                      th= "测试点"
                      th= "结果"
                      th= "CPU"
                      th= "实际时间"
                      th= "内存"
                      th= "退出码"
                      th= "信号"
                      th= "错误码"
                  tbody
                    each item in submission.caseResults
                      tr
                        td.table-code= `#${item.seq_id}`
                        td
                          - const verdictClass = item.verdict === 'AC' ? 'ac' : (item.verdict === 'PENDING' ? 'pending' : 'failed')
                          +statusChip(formatVerdictLabel(item.verdict), verdictClass)
                        td.table-code= `${item.cpu_time_ms} ms`
                        td.table-code= `${item.real_time_ms} ms`
                        td.table-code= `${item.memory_kb} KB`
                        td.table-code= item.exit_code
                        td.table-code= item.signal
                        td.table-code= item.error_code
            else
              p.soft-note= "评测机还没有返回测试点结果。"
      .detail-sidebar
        article.panel-card
          header
            h3= "操作"
          .panel-body
            .form-actions
              a(href=`/problem/${submission.pid}` role="button")= "返回题目"
              a(href=`/problem/${submission.pid}#submit` role="button" class="secondary")= "再提交此题"
              a(href='/submissions' role="button" class="secondary")= "返回提交列表"
              a(href='/problems' role="button" class="contrast")= "打开题目列表"
    +pageScript('/assets/submission-detail.js')
