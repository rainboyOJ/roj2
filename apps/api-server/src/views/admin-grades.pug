//- 管理员年级管理页：维护注册页面可选年级。
extends layout.pug
include mixins/assets.pug

block content
  section.list-panel
    header
      hgroup
        h1= "年级管理"
        p.page-lead= "维护注册页面可选年级，并控制哪些年级启用。"
    article.panel-card.form-card
      .panel-body
        p#adminGradesAlert.form-alert(role="alert" hidden=!formError)= formError || ''
        form.admin-grade-form(method="post" action='/admin/grades')
          .form-grid
            div
              label(for="new-grade-name")= "年级"
              input#new-grade-name(type="text" name="name" value=formValues && formValues.name required)
            div
              label(for="new-grade-order")= "排序"
              input#new-grade-order(type="number" name="order" value=(formValues && formValues.order) || "0" required min="0" step="1")
          label
            input(type="checkbox" name="isActive" value="true" checked=!formValues || formValues.isActive === 'true')
            = "启用"
          button(type="submit")= "创建年级"
    if grades.length
      .table-shell
        table.data-table
          thead
            tr
              th= "年级"
              th= "启用"
              th= "排序"
              th= "操作"
          tbody
            each grade in grades
              tr
                td
                  form.admin-grade-form(method="post" action=`/admin/grades/${grade.id}` id=`grade-form-${grade.id}` data-grade-id=grade.id)
                    input(type="text" name="name" value=grade.name required)
                td
                  label
                    input(type="checkbox" name="isActive" value="true" checked=grade.isActive form=`grade-form-${grade.id}`)
                    = "启用"
                td
                  input(type="number" name="order" value=grade.order form=`grade-form-${grade.id}` required min="0" step="1")
                td
                  button(type="submit" form=`grade-form-${grade.id}`)= "保存"
    else
      article
        p= "当前还没有年级。"

block pageScripts
  +formScripts('admin-grades.js', true)
