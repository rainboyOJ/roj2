//- 首页：给第一次打开项目的人一个总览入口。
extends layout.pug

block content
  .hero-grid
    section.stack-panel
      .hero-panel
        article
          hgroup
            h1= "学校 OJ 练习平台"
            p.page-lead= "一个适合教学场景的简洁在线评测工作区，用来读题、交题和查看结果。"
          p= "这个站点面向学习使用：导航简单、页面清晰，常见 OJ 操作可以直接进入。"
          .page-actions
            a(href='/problems' role="button")= "进入题目列表"
            a(href='/submissions' role="button" class="secondary")= "查看提交记录"
            a(href='/ranklist' role="button" class="contrast")= "打开排行榜"
          form.quick-problem-jump(method="get" action="/problem-jump")
            label(for="quick-problem-pid")
              span= "输入题号快速打开题目"
              input#quick-problem-pid(type="text" name="pid" placeholder="例如 1000" inputmode="numeric" autocomplete="off" required)
            button(type="submit")= "跳转"
      .feature-grid
        article.feature-card
          h3= "开始做题"
          p= "打开题目列表，选择一道题，然后提交 Python 或 C++ 代码。"
        article.feature-card
          h3= "查看结果"
          p= "回到提交记录页面，持续跟踪评测，直到出现最终结果。"
        article.feature-card
          h3= "查看排行"
          p= "打开一个经典 OJ 风格的简洁排行榜页面。"
      section.home-overview
        header
          h3 当前可用
          p 这些入口覆盖了日常练习、查看结果和后台管理，方便测试时快速跳转。
        .metric-grid
          article.metric-card
            strong 题目
            p 查看题面并提交代码。
          article.metric-card
            strong 提交
            p 跟踪状态、分数和评测详情。
          article.metric-card
            strong 排行
            p 查看当前练习完成情况。
          article.metric-card
            strong 管理
            p 维护用户、题目、语言和提交。
    aside.stack-panel
      article.panel-card
        header
          h3= "常用入口"
        .panel-body
          ul.compact-list
            li
              a(href='/problems')= "题目列表"
              small 01
            li
              a(href='/submissions')= "提交列表"
              small 02
            li
              a(href='/ranklist')= "排行榜"
              small 03
            li
              a(href='/contests')= "比赛列表"
              small 04
            li
              a(href='/login')= "账号登录"
              small 05
            li
              a(href='/register')= "学生注册"
              small 06
      article.panel-card
        header
          h3= "学习流程"
        .panel-body
          ol.compact-list
            li
              strong 1
              span= "先阅读题面。"
            li
              strong 2
              span= "先写出一个小而正确的程序。"
            li
              strong 3
              span= "提交后查看评测结果。"
            li
              strong 4
              span= "根据结果继续修改重试。"
