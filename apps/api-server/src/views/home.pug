extends layout.pug

block content
  .hero-grid
    section.stack-panel
      .hero-panel
        article
          hgroup
            h1= t('home.title')
            p.page-lead= t('home.lead')
          p= t('home.description')
          .page-actions
            a(href=urlWithLang('/problems') role="button")= t('home.start.cta')
            a(href=urlWithLang('/submissions') role="button" class="secondary")= t('home.results.cta')
            a(href=urlWithLang('/ranklist') role="button" class="contrast")= t('home.rankings.cta')
      .feature-grid
        article.feature-card
          h3= t('home.start.title')
          p= t('home.start.body')
        article.feature-card
          h3= t('home.results.title')
          p= t('home.results.body')
        article.feature-card
          h3= t('home.rankings.title')
          p= t('home.rankings.body')
    aside.stack-panel
      article.panel-card
        header
          h3= t('home.quickLinks')
        .panel-body
          ul.compact-list
            li
              a(href=urlWithLang('/problems'))= t('problems.title')
              small 01
            li
              a(href=urlWithLang('/submissions'))= t('submissions.title')
              small 02
            li
              a(href=urlWithLang('/ranklist'))= t('ranklist.title')
              small 03
            li
              a(href=urlWithLang('/contests'))= t('contests.title')
              small 04
            li
              a(href=urlWithLang('/login'))= t('login.title')
              small 05
            li
              a(href=urlWithLang('/register'))= t('register.title')
              small 06
      article.panel-card
        header
          h3= t('home.learningFlow')
        .panel-body
          ol.compact-list
            li
              strong 1
              span= t('home.flow.step1')
            li
              strong 2
              span= t('home.flow.step2')
            li
              strong 3
              span= t('home.flow.step3')
            li
              strong 4
              span= t('home.flow.step4')
