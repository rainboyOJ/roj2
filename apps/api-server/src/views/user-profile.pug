//- 公开个人资料页：站内用户可查看其他用户的基础信息和做题进度。
extends layout.pug
include mixins/status.pug

block content
  section.detail-panel
    header
      hgroup
        h1= profile.user.name || profile.user.username
        p.page-lead= `@${profile.user.username} 的个人资料与做题进度。`
    .stats-grid
      article.stat-card
        strong= profile.acceptedCount
        span= "通过题目"
      article.stat-card
        strong= profile.attemptedCount
        span= "尝试题目"
      article.stat-card
        strong= profile.acceptanceRateText
        span= "通过率"
    .detail-grid
      .detail-main
        article.panel-card
          header
            h2= "通过的题目"
          .panel-body
            if profile.acceptedProblems.length
              ul.problem-link-list
                each problem in profile.acceptedProblems
                  li
                    a(href=`/problem/${problem.pid}`)= problem.label
            else
              p= "还没有通过可见题目。"
        article.panel-card
          header
            h2= "尝试但未通过的题目"
          .panel-body
            if profile.attemptedProblems.length
              ul.problem-link-list
                each problem in profile.attemptedProblems
                  li
                    a(href=`/problem/${problem.pid}`)= problem.label
            else
              p= "没有尝试但未通过的可见题目。"
      .detail-sidebar
        article.panel-card
          header
            h3= "个人信息"
          .panel-body
            .info-stack
              .info-item
                strong= "用户名"
                p.table-code= profile.user.username
              .info-item
                strong= "姓名"
                p= profile.user.name || "未填写"
              .info-item
                strong= "年级"
                p= profile.user.grade || "未填写"
              .info-item
                strong= "班级"
                p= profile.user.className || "未填写"
              .info-item
                strong= "角色"
                p= formatRoleLabel(profile.user.role)
              .info-item
                strong= "审核状态"
                p
                  +approvalStatusChip(profile.user.approvalStatus)
