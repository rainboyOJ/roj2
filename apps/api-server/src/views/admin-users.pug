//- 管理员用户审核页：
//- - 顶部按钮做批量审核
//- - 行内按钮做单条审核
extends layout.pug
include mixins/assets.pug
include mixins/pagination.pug
include mixins/status.pug

block content
  - const currentFilters = filters || {}
  - const listPageSuffix = currentPageSuffix || ''
  - const listPaginationQuerySuffix = paginationQuerySuffix || ''
  section.list-panel
    header
      hgroup
        h1= "用户管理"
        p.page-lead= "查看当前账号列表和审核状态，并按用户名或姓名搜索。"
    if formError
      article
        p.form-alert(role="alert")= formError
    form.filter-toolbar(method="get" action="/admin/users")
      label(for="admin-user-search-q")
        span= "用户名或姓名"
        input#admin-user-search-q(type="search" name="q" value=currentFilters.q || '' placeholder="例如 alice 或 张三")
      label(for="admin-user-filter-status")
        span= "审核状态"
        select#admin-user-filter-status(name="approvalStatus")
          option(value="" selected=!currentFilters.approvalStatus)= "全部"
          option(value="pending" selected=currentFilters.approvalStatus === 'pending')= "待审核"
          option(value="approved" selected=currentFilters.approvalStatus === 'approved')= "已通过"
          option(value="rejected" selected=currentFilters.approvalStatus === 'rejected')= "已拒绝"
      label(for="admin-user-filter-class")
        span= "班级"
        select#admin-user-filter-class(name="className")
          option(value="" selected=!currentFilters.className)= "全部"
          each classRecord in classes || []
            option(value=classRecord.name selected=currentFilters.className === classRecord.name)= classRecord.name
      .form-actions
        button(type="submit")= "查询"
        if currentFilters.q || currentFilters.approvalStatus || currentFilters.className
          a(href="/admin/users" role="button" class="secondary")= "清空"
    if users.length
      .page-actions
        a(href=`/admin/users${listPageSuffix}` role="button" class="secondary")= "刷新"
        button(
          type="submit"
          form="bulk-user-review-form"
          formaction=`/admin/users/bulk-approve${listPageSuffix}`
          data-confirm-message="确定要通过选中的用户吗？"
        )= "批量通过"
        button(
          type="submit"
          class="secondary"
          form="bulk-user-review-form"
          formaction=`/admin/users/bulk-reject${listPageSuffix}`
          data-confirm-message="确定要拒绝选中的用户吗？"
        )= "批量拒绝"
      form#bulk-user-review-form(
        method="post"
        action=`/admin/users/bulk-approve${listPageSuffix}`
        data-require-checked="userIds"
        data-empty-message="请先选择需要处理的用户"
      )
      .table-shell
        table.data-table
          thead
            tr
              th
                input#select-current-page-users(
                  type="checkbox"
                  aria-label="选择当前页用户"
                )
              th= "用户名"
              th= "姓名"
              th= "角色"
              th= "审核状态"
              th= "审核操作"
          tbody
            each user in users
              tr
                td
                  if user.role !== 'admin'
                    input(type="checkbox" name="userIds" value=user.id form="bulk-user-review-form")
                td.table-code= user.username
                td= user.name || "没有显示姓名"
                td= formatRoleLabel(user.role)
                td
                  +approvalStatusChip(user.approvalStatus)
                td
                  if user.role !== 'admin'
                    .table-actions
                      form(
                        method="post"
                        action=`/admin/users/bulk-approve${listPageSuffix}`
                        data-confirm-message=`确定要通过用户 ${user.username} 吗？`
                      )
                        input(type="hidden" name="userIds" value=user.id)
                        button(type="submit" id=`approve-user-${user.id}`)= "通过"
                      form(
                        method="post"
                        action=`/admin/users/bulk-reject${listPageSuffix}`
                        data-confirm-message=`确定要拒绝用户 ${user.username} 吗？`
                      )
                        input(type="hidden" name="userIds" value=user.id)
                        button(type="submit" class="secondary" id=`reject-user-${user.id}`)= "拒绝"
                      form(
                        method="post"
                        action=`/admin/users/${user.id}/reset-password${listPageSuffix}`
                        data-confirm-message=`确定要重置用户 ${user.username} 的密码吗？`
                        data-require-password="password"
                        data-password-empty-message="请先输入新密码"
                      )
                        input(type="password" name="password" placeholder="新密码" autocomplete="new-password")
                        button(type="submit" class="secondary" id=`reset-password-user-${user.id}`)= "重置密码"
                      form(
                        method="post"
                        action=`/admin/users/${user.id}/delete${listPageSuffix}`
                        data-confirm-message=`确定要删除用户 ${user.username} 吗？删除后不可恢复。`
                        data-delete-submissions-message=`是否同时清空用户 ${user.username} 的提交记录和做题进度？`
                      )
                        input(type="hidden" name="deleteSubmissions" value="false")
                        button(type="submit" class="contrast" id=`delete-user-${user.id}`)= "删除用户"
      +paginationBar('/admin/users', pagination, '用户管理分页', listPaginationQuerySuffix)
    else
      article
        if currentFilters.q || currentFilters.approvalStatus || currentFilters.className
          p= "没有找到符合条件的用户。"
        else
          p= "没有需要查看的用户。"

block pageScripts
  +formScripts('admin-users.js', true)
