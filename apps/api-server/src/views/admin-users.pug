//- 管理员用户审核页：
//- - 顶部按钮做批量审核
//- - 行内按钮做单条审核
extends layout.pug
include mixins/assets.pug

block content
  section.list-panel
    header
      hgroup
        h1= "用户管理"
        p.page-lead= "查看当前账号列表和审核状态。"
    if formError
      article
        p.form-alert(role="alert")= formError
    if users.length
      .page-actions
        button(
          type="submit"
          form="bulk-user-review-form"
          formaction='/admin/users/bulk-approve'
          data-confirm-message="确定要通过选中的用户吗？"
        )= "批量通过"
        button(
          type="submit"
          class="secondary"
          form="bulk-user-review-form"
          formaction='/admin/users/bulk-reject'
          data-confirm-message="确定要拒绝选中的用户吗？"
        )= "批量拒绝"
      form#bulk-user-review-form(
        method="post"
        action='/admin/users/bulk-approve'
        data-require-checked="userIds"
        data-empty-message="请先选择需要处理的用户"
      )
      .table-shell
        table.data-table
          thead
            tr
              th= "选择"
              th= "用户名"
              th= "姓名"
              th= "角色"
              th= "审核状态"
              th= "审核操作"
          tbody
            each user in users
              tr
                td
                  if user.role !== 'admin'
                    input(type="checkbox" name="userIds" value=user.id form="bulk-user-review-form")
                td.table-code= user.username
                td= user.name || "没有显示姓名"
                td= formatRoleLabel(user.role)
                td
                  if user.approvalStatus === 'approved'
                    span.status-chip.ac= formatApprovalStatusLabel(user.approvalStatus)
                  else if user.approvalStatus === 'rejected'
                    span.status-chip.failed= formatApprovalStatusLabel(user.approvalStatus)
                  else
                    span.status-chip.pending= formatApprovalStatusLabel(user.approvalStatus)
                td
                  if user.role !== 'admin'
                    .table-actions
                      form(
                        method="post"
                        action='/admin/users/bulk-approve'
                        data-confirm-message=`确定要通过用户 ${user.username} 吗？`
                      )
                        input(type="hidden" name="userIds" value=user.id)
                        button(type="submit" id=`approve-user-${user.id}`)= "通过"
                      form(
                        method="post"
                        action='/admin/users/bulk-reject'
                        data-confirm-message=`确定要拒绝用户 ${user.username} 吗？`
                      )
                        input(type="hidden" name="userIds" value=user.id)
                        button(type="submit" class="secondary" id=`reject-user-${user.id}`)= "拒绝"
                      form(
                        method="post"
                        action=`/admin/users/${user.id}/reset-password`
                        data-confirm-message=`确定要重置用户 ${user.username} 的密码吗？`
                        data-require-password="password"
                        data-password-empty-message="请先输入新密码"
                      )
                        input(type="password" name="password" placeholder="新密码" autocomplete="new-password")
                        button(type="submit" class="secondary" id=`reset-password-user-${user.id}`)= "重置密码"
                      form(
                        method="post"
                        action=`/admin/users/${user.id}/delete`
                        data-confirm-message=`确定要删除用户 ${user.username} 吗？删除后不可恢复。`
                      )
                        button(type="submit" class="contrast" id=`delete-user-${user.id}`)= "删除用户"
    else
      article
        p= "没有需要查看的用户。"

block pageScripts
  +formScripts('admin-users.js', true)
