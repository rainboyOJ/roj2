extends layout.pug

block content
  .page-stack
    .page-header
      .page-eyebrow Account
      h1.page-title Sign in
      p.page-description
        | Use your account to submit code, view results, and access the learning workflow.
    .form-card
      form.form-grid(method="post" action="/api/login")
        .field
          label(for="username") Username
          input#username(type="text" name="username" placeholder="demo")
        .field
          label(for="password") Password
          input#password(type="password" name="password" placeholder="Enter your password")
        .button-row
          button(type="submit") Sign in
          a.button.button--secondary(href="/register") Create account
