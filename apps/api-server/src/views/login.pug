extends layout.pug

block content
  section.auth-panel
    header
      hgroup
        h1 Account login
        p.page-lead Sign in to submit code, review your history, and access the common OJ pages.
    article
      form(method="post" action="/api/login")
        label(for="username") Username
        input#username(type="text" name="username" placeholder="demo")
        label(for="password") Password
        input#password(type="password" name="password" placeholder="Enter your password")
        .grid
          button(type="submit") Sign in
          a(href="/register" role="button" class="secondary") Create account
