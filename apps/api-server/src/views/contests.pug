extends layout.pug

block content
  section.list-panel
    header
      hgroup
        h1= t('contests.title')
        p.page-lead= t('contests.lead')
    if contests.length
      each contest in contests
        article
          header
            h2
              a(href=urlWithLang(`/contests/${contest.id}`))= contest.title
            p.soft-note= contest.description
          ul.compact-meta
            li
              span.status-chip.pending= localizeContestStatus(contest.status)
            li #{t('contests.start')}: #{contest.startAtText}
            li #{t('contests.end')}: #{contest.endAtText}
          footer
            a(href=urlWithLang(`/contests/${contest.id}`))= t('contests.open')
    else
      article
        p= t('contests.empty')
