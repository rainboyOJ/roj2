//- 排行榜页：当前实现是一个简化版 OJ 排名表。
extends layout.pug

block content
  - const currentFilters = filters || {}
  section.list-panel
    header
      hgroup
        h1= "排行榜"
        p.page-lead= "一个简化的学校 OJ 排行榜，按通过题数和最近通过时间展示。"
    form.filter-toolbar(method="get" action="/ranklist")
      label(for="ranklist-filter-class")
        span= "班级"
        select#ranklist-filter-class(name="className")
          option(value="")= "全部班级"
          each classRecord in classes
            option(value=classRecord.name selected=currentFilters.className === classRecord.name)= classRecord.name
      .form-actions
        button(type="submit")= "查询"
        if currentFilters.className
          a(href="/ranklist" role="button" class="secondary")= "清空"
    if entries.length
      .table-shell
        table.data-table
          thead
            tr
              th= "排名"
              th= "姓名"
              th= "班级"
              th= "通过题数"
              th= "总提交数"
              th= "最近 AC"
          tbody
            each entry in entries
              tr
                td.table-code= `#${entry.rank}`
                td= entry.displayName ? `${entry.displayName} (${entry.username})` : entry.username
                td= entry.className || "未填写"
                td= entry.acceptedCount
                td= entry.submissionCount
                td= entry.lastAcceptedAt || "暂无"
    else
      article
        p= "暂无排行数据。"
