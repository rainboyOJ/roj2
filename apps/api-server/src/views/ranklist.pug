//- 排行榜页：当前实现是一个简化版 OJ 排名表。
extends layout.pug

block content
  section.list-panel
    header
      hgroup
        h1= "排行榜"
        p.page-lead= "一个简化的学校 OJ 排行榜，按通过题数和最近通过时间展示。"
    if entries.length
      .table-shell
        table.data-table
          thead
            tr
              th= "排名"
              th= "用户"
              th= "通过题数"
              th= "总提交数"
              th= "最近 AC"
          tbody
            each entry in entries
              tr
                td.table-code= `#${entry.rank}`
                td= entry.username
                td= entry.acceptedCount
                td= entry.submissionCount
                td= entry.lastAcceptedAt || "暂无"
    else
      article
        p= "暂无排行数据。"
