mixin paginationBar(basePath, pagination, ariaLabel, querySuffix)
  - const suffix = querySuffix ? `&${querySuffix}` : ''
  - const currentPage = pagination.page
  - const totalPages = Math.max(1, pagination.totalPages || 1)
  - const pageHref = (page) => `${basePath}?page=${page}${suffix}`
  - const pageItems = []
  - const pushPage = (page) => pageItems.push({ type: 'page', page })
  - const pushEllipsis = () => pageItems.push({ type: 'ellipsis' })
  - if (totalPages <= 9) {
  -   for (let page = 1; page <= totalPages; page += 1) pushPage(page)
  - } else {
  -   const windowStart = Math.max(2, currentPage - 2)
  -   const windowEnd = Math.min(totalPages - 1, currentPage + 2)
  -   pushPage(1)
  -   if (windowStart > 2) pushEllipsis()
  -   for (let page = windowStart; page <= windowEnd; page += 1) pushPage(page)
  -   if (windowEnd < totalPages - 1) pushEllipsis()
  -   pushPage(totalPages)
  - }
  nav.pagination-bar(aria-label=ariaLabel)
    if currentPage > 1
      a.pagination-item(href=pageHref(1) aria-label="第一页") <<
      a.pagination-item(href=pageHref(currentPage - 1) aria-label="上一页") <
    else
      span.pagination-item.pagination-disabled(aria-disabled="true") <<
      span.pagination-item.pagination-disabled(aria-disabled="true") <
    each item in pageItems
      if item.type === 'ellipsis'
        span.pagination-ellipsis(aria-hidden="true") ...
      else if item.page === currentPage
        span.pagination-item.pagination-current(aria-current="page")= item.page
      else
        a.pagination-item(href=pageHref(item.page))= item.page
    if currentPage < totalPages
      a.pagination-item(href=pageHref(currentPage + 1) aria-label="下一页") >
      a.pagination-item(href=pageHref(totalPages) aria-label="最后一页") >>
    else
      span.pagination-item.pagination-disabled(aria-disabled="true") >
      span.pagination-item.pagination-disabled(aria-disabled="true") >>
    span.pagination-summary= `共有 ${totalPages} 页`
