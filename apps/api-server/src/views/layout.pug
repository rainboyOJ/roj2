doctype html
html(lang=lang === 'zh' ? 'zh-CN' : 'en')
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title= pageTitle ? `${pageTitle} | ROJ` : 'ROJ'
    meta(name="color-scheme" content="light")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.classless.min.css")
    style.
      :root {
        --pico-font-family-sans-serif: "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif;
        --pico-font-size: 95%;
        --pico-line-height: 1.65;
        --pico-border-radius: 0.85rem;
        --pico-nav-element-spacing-horizontal: 0.75rem;
        --pico-nav-element-spacing-vertical: 0.4rem;
      }

      body {
        background: #f7f8fb;
      }

      main.container {
        padding-top: 1.5rem;
        padding-bottom: 3rem;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(10px);
        background: rgba(247, 248, 251, 0.92);
        border-bottom: 1px solid #e5e7eb;
      }

      .site-header nav {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0.8rem 1rem;
      }

      .brand-block {
        display: inline-flex;
        flex-direction: column;
        gap: 0.1rem;
      }

      .brand-block small {
        color: #526077;
      }

      .lang-switch {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.92rem;
        color: #526077;
      }

      .lang-switch a[aria-current="true"] {
        font-weight: 700;
        text-decoration: underline;
      }

      .page-lead {
        max-width: 68ch;
      }

      .page-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: center;
        margin: 1rem 0 0;
      }

      .hero-panel {
        padding: 1rem 0 0.5rem;
      }

      .hero-panel article,
      .list-panel article,
      .detail-panel article,
      .auth-panel article {
        height: 100%;
      }

      .metric-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
      }

      .metric-card {
        padding: 1rem;
        border: 1px solid #dbe2ea;
        border-radius: 0.85rem;
        background: #fff;
      }

      .metric-card strong {
        display: block;
        font-size: 1.4rem;
      }

      .list-panel header,
      .detail-panel header,
      .auth-panel header {
        margin-bottom: 1rem;
      }

      .soft-note {
        color: #5f6d81;
      }

      .compact-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        padding: 0;
        margin: 0;
        list-style: none;
        color: #5f6d81;
      }

      .status-chip {
        display: inline-block;
        padding: 0.2rem 0.65rem;
        border-radius: 999px;
        border: 1px solid #d5dce5;
        background: #f9fafb;
        font-size: 0.88rem;
      }

      .status-chip.ac {
        color: #17603a;
        background: #edf8f1;
        border-color: #cae9d4;
      }

      .status-chip.pending {
        color: #8b5a00;
        background: #fff7e8;
        border-color: #f2ddb3;
      }

      .status-chip.failed {
        color: #9a2332;
        background: #fdeef0;
        border-color: #efcbd1;
      }

      .mono-block {
        font-family: "JetBrains Mono", "SFMono-Regular", "Consolas", monospace;
        white-space: pre-wrap;
        word-break: break-word;
      }

      textarea[name="sourceCode"] {
        min-height: 22rem;
        font-family: "JetBrains Mono", "SFMono-Regular", "Consolas", monospace;
      }

      @media (max-width: 768px) {
        .metric-grid {
          grid-template-columns: 1fr;
        }
      }
  body
    header.site-header
      nav
        ul
          li
            a(href=urlWithLang('/'))
              span.brand-block
                strong ROJ
                small= t('site.tagline')
        ul
          li
            a(href=urlWithLang('/'))= t('nav.home')
          li
            a(href=urlWithLang('/problems'))= t('nav.problems')
          li
            a(href=urlWithLang('/submissions'))= t('nav.submissions')
          li
            a(href=urlWithLang('/ranklist'))= t('nav.ranklist')
          li
            a(href=urlWithLang('/contests'))= t('nav.contests')
          li
            a(href=urlWithLang('/profile'))= t('nav.profile')
          li
            a(href=urlWithLang('/login'))= t('nav.login')
          li
            a(href=urlWithLang('/register'))= t('nav.register')
          li
            details.dropdown
              summary= t('nav.admin')
              ul(dir="rtl")
                li
                  a(href=urlWithLang('/admin/users'))= t('nav.admin.users')
                li
                  a(href=urlWithLang('/admin/problems'))= t('nav.admin.problems')
                li
                  a(href=urlWithLang('/admin/submissions'))= t('nav.admin.submissions')
          li
            span.lang-switch
              a(
                href=currentUrlForLang('zh')
                aria-current=lang === 'zh'
              )= t('lang.zh')
              span /
              a(
                href=currentUrlForLang('en')
                aria-current=lang === 'en'
              )= t('lang.en')
    main.container
      block content
