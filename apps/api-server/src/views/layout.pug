//- 所有页面都继承这个布局文件。
//- 它负责提供统一的 nav、整体样式，以及普通区 / 管理区的导航切换。
doctype html
html(lang="zh-CN" data-theme="light")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title= pageTitle ? `${pageTitle} | ROJ` : 'ROJ'
    meta(name="color-scheme" content="light")
    link(rel="icon" href=assetUrl('/favicon.svg') type="image/svg+xml")
    link(rel="stylesheet" href=assetUrl('/assets/pico.min.css'))
    link(rel="stylesheet" href=assetUrl('/assets/katex.min.css'))
    link(rel="stylesheet" href=assetUrl('/assets/notyf.min.css'))
    link(rel="stylesheet" href=assetUrl('/assets/site.css'))
  body
    header.site-header
      nav
        .nav-brand
          a(href=isAdminArea ? '/admin' : '/')
            span.brand-block
              strong ROJ
              small= isAdminArea ? "管理" : "简单学校 OJ"
        .nav-links
          if isAdminArea
            a(href='/admin/problems')= "题目管理"
            a(href='/admin/problem-sets')= "题目单"
            a(href='/admin/settings/languages')= "语言设置"
            a(href='/admin/grades')= "年级管理"
            a(href='/admin/classes')= "班级管理"
            a(href='/admin/submissions')= "提交管理"
            a(href='/admin/users')= "用户"
            a(href='/')= "首页"
          else
            a(href='/')= "首页"
            a(href='/problems')= "题目"
            a(href='/problem-sets')= "题目单"
            a(href='/submissions')= "提交"
            a(href='/ranklist')= "排行榜"
            a(href='/contests')= "比赛"
            if currentUser
              if currentUser.role === 'admin'
                a(href='/admin' role="button" class="secondary")= "管理"
              a(href='/profile')= "个人中心"
              form(method="post" action='/logout')
                button(type="submit" class="secondary")= "登出"
            else
              a(href='/login')= "登录"
              a(href='/register')= "注册"
    main.container
      block content
    block pageScripts
