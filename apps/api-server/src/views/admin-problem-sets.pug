//- 管理员题目单列表页。
extends layout.pug
include mixins/status.pug

block content
  - const listPageSuffix = currentPageSuffix || ''
  section.list-panel
    header
      hgroup
        h1= "题目单管理"
        p.page-lead= "创建、编辑和发布面向学生的训练题目单。"
      .page-actions
        a(href=`/admin/problem-sets/new${listPageSuffix}` role="button")= "创建题目单"
    if formError
      article
        p.form-alert(role="alert")= formError
    if problemSets.length
      .table-shell
        table.data-table
          thead
            tr
              th= "标题"
              th= "题目数量"
              th= "状态"
              th= "更新时间"
              th= "操作"
          tbody
            each problemSet in problemSets
              tr
                td= problemSet.title
                td= problemSet.problemRefs.length
                td
                  +problemSetPublishChip(problemSet.isPublished)
                td= problemSet.updatedAtText
                td
                  .table-actions
                    a(href=`/admin/problem-sets/${problemSet.id}/edit${listPageSuffix}`)= "编辑"
                    if !problemSet.isPublished
                      form(method="post" action=`/admin/problem-sets/${problemSet.id}/publish${listPageSuffix}`)
                        button(type="submit" class="secondary")= "发布"
                    else
                      form(
                        method="post"
                        action=`/admin/problem-sets/${problemSet.id}/hide${listPageSuffix}`
                        data-confirm-message=`确定要隐藏题目单 ${problemSet.title} 吗？隐藏后学生将无法看到。`
                        onsubmit="return window.confirm(this.dataset.confirmMessage)"
                      )
                        button(type="submit" class="secondary")= "隐藏"
                    form(
                      method="post"
                      action=`/admin/problem-sets/${problemSet.id}/delete${listPageSuffix}`
                      data-confirm-message=`确定要删除题目单 ${problemSet.title} 吗？删除后不可恢复。`
                      onsubmit="return window.confirm(this.dataset.confirmMessage)"
                    )
                      button(type="submit" class="contrast")= "删除"
    else
      article
        p= "当前还没有题目单。"
