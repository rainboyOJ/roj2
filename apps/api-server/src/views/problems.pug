//- 题目列表页：普通用户最常进入的页面之一。
extends layout.pug
include mixins/pagination.pug

block content
  section.list-panel
    header
      hgroup
        h1= "题目列表"
        p.page-lead= "浏览公开题目，打开题面，并在详情页提交代码。"
      .page-actions
        a(href='/submissions' role="button" class="secondary")= "提交列表"
        if !currentUser
          a(href='/login' role="button" class="contrast")= "登录"
    form.filter-form(method="get" action="/problems" aria-label="题目筛选")
      label
        span= "搜索"
        input(
          type="search"
          name="q"
          placeholder="题号或标题"
          value=filters && filters.q ? filters.q : ''
        )
      if currentUser
        label
          span= "状态"
          select(name="progress")
            option(value="" selected=!(filters && filters.progress)) 全部
            option(value="accepted" selected=filters && filters.progress === 'accepted') 已通过
            option(value="attempted" selected=filters && filters.progress === 'attempted') 已尝试
            option(value="empty" selected=filters && filters.progress === 'empty') 未开始
      .filter-actions
        button(type="submit")= "筛选"
        if (filters && (filters.q || filters.progress))
          a(href="/problems" role="button" class="secondary")= "清空"
    if problems.length
      .table-shell
        table.data-table
          thead
            tr
              th.problem-progress-cell 状态
              th= "题号"
              th= "题目"
              th= "支持语言"
              th= "操作"
          tbody
            each problem in problems
              tr(class=problem.progress === 'accepted' ? 'problem-row-accepted' : '')
                td.problem-progress-cell
                  if problem.progress === 'accepted'
                    span.problem-progress-icon.accepted(title="已通过" aria-label="已通过")
                      svg(viewBox="0 0 24 24" width="16" height="16" aria-hidden="true")
                        path(d="M20 6 9 17l-5-5" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round")
                  else if problem.progress === 'attempted'
                    span.problem-progress-icon.attempted(title="已尝试" aria-label="已尝试")
                      svg(viewBox="0 0 24 24" width="16" height="16" aria-hidden="true")
                        path(d="M5 12h14" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round")
                td.table-code= problem.pid
                td
                  strong
                    a(href=`/problem/${problem.pid}`)= problem.title
                td= problem.allowLanguages.join(', ')
                td
                  a(href=`/problem/${problem.pid}`)= "提交代码"
      +paginationBar('/problems', pagination, '题目列表分页', paginationQuerySuffix)
    else
      article
        p= filters && (filters.q || filters.progress) ? "没有找到符合条件的题目。" : "目前还没有可见题目。"
