extends layout.pug

block content
  section.list-panel
    header
      hgroup
        h1 Problem list
        p.page-lead Browse public problems, open a statement, and submit code from the detail page.
      .page-actions
        a(href="/submissions" role="button" class="secondary") Submission list
        a(href="/login" role="button" class="contrast") Login
    if problems.length
      each problem in problems
        article
          header
            h2
              a(href=`/problem/${problem.pid}`)= `${problem.pid} - ${problem.title}`
            p.soft-note Submit code, check verdicts, and revisit this problem anytime.
          ul.compact-meta
            li PID: #{problem.pid}
            li Languages: #{problem.allowLanguages.join(', ')}
          footer
            a(href=`/problem/${problem.pid}`) Submit code
    else
      article
        p No visible problems yet.
