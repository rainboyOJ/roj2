//- 管理员题目列表页：用于查看、编辑、发布题目。
extends layout.pug
include mixins/assets.pug

block content
  section.list-panel
    header
      hgroup
        h1= "题目管理"
        p.page-lead= "按 OJ 管理员常见的方式浏览和维护题目目录。"
      .page-actions
        a(href='/admin/problems/new' role="button")= "创建题目"
    if formError
      article
        p.form-alert(role="alert")= formError
    if problems.length
      .table-shell
        table.data-table
          thead
            tr
              th= "题号"
              th= "标题"
              th= "支持语言"
              th= "可见性"
              th= "操作"
          tbody
            each problem in problems
              tr
                td.table-code= problem.pid
                td= problem.title
                td= problem.allowLanguages.join(', ')
                td
                  if problem.isVisible
                    span.status-chip.ac= "可见"
                  else
                    span.status-chip.pending= "隐藏"
                td
                  .table-actions
                    a(href=`/admin/problems/${problem.id}/edit`)= "编辑"
                    if !problem.isVisible
                      form.admin-publish-problem-form(method="post" action=`/admin/problems/${problem.id}/publish` data-problem-id=problem.id)
                        button(type="submit" class="secondary")= "发布"
    else
      article
        p= "当前还没有题目。"

block pageScripts
  +formScripts('admin-problems.js', true)
