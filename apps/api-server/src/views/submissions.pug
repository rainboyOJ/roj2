//- 提交列表页：查看自己的提交历史和结果概览。
extends layout.pug

block content
  section.list-panel
    header
      hgroup
        h1= t('submissions.title')
        p.page-lead= t('submissions.lead')
      .page-actions
        a(href=urlWithLang('/problems') role="button" class="secondary")= t('submissions.problemList')
    if submissions.length
      .table-shell
        table.data-table
          thead
            tr
              th= t('submissions.submissionId')
              th= t('submissions.user')
              th= t('submissions.problem')
              th= t('submissions.language')
              th= t('submissions.score')
              th= t('submissions.status')
              th= t('submissions.judge')
              th= t('submissions.verdict')
              th= t('submissions.action')
          tbody
            each submission in submissions
              tr
                td.table-code
                  a(href=urlWithLang(`/submissions/${submission.publicId}`))= submission.publicId
                td= submission.displayName ? `${submission.displayName} (${submission.username})` : submission.username
                td
                  a(href=urlWithLang(`/problem/${submission.pid}`))= submission.problemLabel
                td.table-code= submission.language
                td.table-code= submission.score
                td= localizeStatus(submission.status)
                td= submission.judgeStatus ? localizeJudgeStatus(submission.judgeStatus) : '-'
                td
                  if submission.verdict === 'AC'
                    span.status-chip.ac= localizeVerdict(submission.verdict)
                  else if submission.verdict === 'PENDING'
                    span.status-chip.pending= localizeVerdict(submission.verdict)
                  else
                    span.status-chip.failed= localizeVerdict(submission.verdict)
                td
                  a(href=urlWithLang(`/submissions/${submission.publicId}`))= t('submissions.details')
      nav.pagination-bar(aria-label="提交列表分页")
        if pagination.previousPage
          a(href=urlWithLang(`/submissions?page=${pagination.previousPage}`) role="button" class="secondary") 上一页
        else
          span.pagination-disabled 上一页
        span.pagination-summary= `第 ${pagination.page} / ${pagination.totalPages} 页，共 ${pagination.total} 条`
        if pagination.nextPage
          a(href=urlWithLang(`/submissions?page=${pagination.nextPage}`) role="button" class="secondary") 下一页
        else
          span.pagination-disabled 下一页
    else
      article
        p= t('submissions.empty')
