extends layout.pug

block content
  section.list-panel
    header
      hgroup
        h1 Submission list
        p.page-lead Review recent judging activity and reopen any submission for details.
      .page-actions
        a(href="/problems" role="button" class="secondary") Problem list
    if submissions.length
      each submission in submissions
        article
          header
            h2
              a(href=`/submissions/${submission.id}`)= submission.id
            p.soft-note Track the result of this submission from queued to final verdict.
          ul.compact-meta
            li Status: #{submission.status}
            if submission.judgeStatus
              li Judge: #{submission.judgeStatus}
            li
              if submission.verdict === 'AC'
                span.status-chip.ac= submission.verdict
              else if submission.verdict === 'PENDING'
                span.status-chip.pending= submission.verdict
              else
                span.status-chip.failed= submission.verdict
          footer
            a(href=`/submissions/${submission.id}`) Details
    else
      article
        p No submissions yet.
