extends layout.pug

block content
  .page-stack
    .page-header
      .page-eyebrow History
      h1.page-title Recent submissions
      p.page-description
        | Review your latest judging results and reopen any submission details page for more context.
    if submissions.length
      .table-list
        each submission in submissions
          article.table-row
            div
              h2.card-title
                a(href=`/submissions/${submission.id}`)= submission.id
              ul.meta-list
                li Status: #{submission.status}
                if submission.judgeStatus
                  li Judge: #{submission.judgeStatus}
            div
              if submission.verdict === 'AC'
                span.badge.badge--success= submission.verdict
              else if submission.verdict === 'PENDING'
                span.badge.badge--warning= submission.verdict
              else
                span.badge.badge--danger= submission.verdict
            a.button.button--secondary(href=`/submissions/${submission.id}`) Details
    else
      .empty-state No submissions yet.
