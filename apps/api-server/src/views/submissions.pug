//- 提交列表页：查看自己的提交历史和结果概览。
extends layout.pug
include mixins/pagination.pug
include mixins/status.pug

block content
  - const currentFilters = filters || {}
  - const listPaginationQuerySuffix = paginationQuerySuffix || ''
  section.list-panel
    header
      hgroup
        h1= "提交列表"
        p.page-lead= "查看全站评测记录，并按题目或用户快速筛选。"
      .page-actions
        a(href='/problems' role="button" class="secondary")= "题目列表"
    form.filter-toolbar(method="get" action="/submissions")
      label(for="submission-filter-pid")
        span= "题目编号"
        input#submission-filter-pid(type="text" name="pid" value=currentFilters.pid || '' placeholder="例如 1000")
      label(for="submission-filter-user")
        span= "用户"
        input#submission-filter-user(type="text" name="user" value=currentFilters.user || '' placeholder="用户名或姓名")
      label(for="submission-filter-language")
        span= "语言"
        select#submission-filter-language(name="language")
          option(value="" selected=!currentFilters.language)= "全部"
          option(value="cpp" selected=currentFilters.language === 'cpp')= "C++"
          option(value="python" selected=currentFilters.language === 'python')= "Python"
      .form-actions
        button(type="submit")= "查询"
        if currentFilters.pid || currentFilters.user || currentFilters.language
          a(href="/submissions" role="button" class="secondary")= "清空"
    if submissions.length
      .table-shell
        table.data-table
          thead
            tr
              th= "提交号"
              th= "用户"
              th= "题目"
              th= "语言"
              th= "分数"
              th= "状态"
              th= "评测机"
              th= "结果"
              th= "操作"
          tbody
            each submission in submissions
              tr
                td.table-code
                  a(href=`/submissions/${submission.publicId}`)= submission.publicId
                td= submission.displayName ? `${submission.displayName} (${submission.username})` : submission.username
                td
                  a(href=`/problem/${submission.pid}`)= submission.problemLabel
                td.table-code= submission.language
                td.table-code= submission.score
                td= formatStatusLabel(submission.status)
                td= submission.judgeStatus ? formatJudgeStatusLabel(submission.judgeStatus) : '-'
                td
                  +verdictChip(submission.verdict)
                td
                  a(href=`/submissions/${submission.publicId}`)= "查看详情"
      +paginationBar('/submissions', pagination, '提交列表分页', listPaginationQuerySuffix)
    else
      article
        p= "没有找到符合条件的提交记录。"
