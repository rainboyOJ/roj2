//- 个人中心页：展示最基础的账号信息。
extends layout.pug

block content
  section.detail-panel
    header
      hgroup
        h1= t('profile.title')
        p.page-lead= t('profile.lead')
    .detail-grid
      .detail-main
        article.panel-card
          header
            h2= t('profile.title')
          .panel-body
            .info-stack
              .info-item
                strong= t('profile.username')
                p.table-code= user.username
              .info-item
                strong= t('profile.role')
                p= localizeRole(user.role)
      .detail-sidebar
        article.panel-card
          header
            h3= t('profile.approval')
          .panel-body
            if user.approvalStatus === 'approved'
              span.status-chip.ac= localizeApprovalStatus(user.approvalStatus)
            else if user.approvalStatus === 'rejected'
              span.status-chip.failed= localizeApprovalStatus(user.approvalStatus)
            else
              span.status-chip.pending= localizeApprovalStatus(user.approvalStatus)
        article.panel-card
          header
            h3= t('profile.password')
          .panel-body
            form(method="post" action=urlWithLang('/profile/password'))
              label(for="currentPassword")= t('profile.currentPassword')
              input#currentPassword(type="password" name="currentPassword")
              label(for="newPassword")= t('profile.newPassword')
              input#newPassword(type="password" name="newPassword")
              button(type="submit")= t('profile.updatePassword')
