//- 个人中心页：展示最基础的账号信息。
extends layout.pug
include mixins/assets.pug
include mixins/status.pug

block content
  section.detail-panel
    header
      hgroup
        h1= "个人中心"
        p.page-lead= "当前用户的基础账号信息。"
    .detail-grid
      .detail-main
        article.panel-card
          header
            h2= "个人中心"
          .panel-body
            .info-stack
              .info-item
                strong= "用户名"
                p.table-code= user.username
              .info-item
                strong= "姓名"
                p= user.name || "未填写"
              .info-item
                strong= "年级"
                p= user.grade || "未填写"
              .info-item
                strong= "班级"
                p= user.className || "未填写"
              .info-item
                strong= "角色"
                p= formatRoleLabel(user.role)
      .detail-sidebar
        article.panel-card
          header
            h3= "审核状态"
          .panel-body
            +approvalStatusChip(user.approvalStatus)
        article.panel-card
          header
            h3= "修改密码"
          .panel-body
            p#profilePasswordAlert.form-alert(role="alert" hidden=!formError)= formError || ''
            form#profilePasswordForm(method="post" action='/profile/password')
              label(for="currentPassword")= "当前密码"
              input#currentPassword(type="password" name="currentPassword" required autocomplete="current-password")
              label(for="newPassword")= "新密码"
              input#newPassword(type="password" name="newPassword" required minlength="8" autocomplete="new-password")
              button(type="submit")= "更新密码"
        article.panel-card
          header
            h3= "修改班级"
          .panel-body
            p#profileClassAlert.form-alert(role="alert" hidden)
            form#profileClassForm
              label(for="profileClassName")= "班级"
              select#profileClassName(name="className" required)
                each classRecord in classes
                  option(value=classRecord.name selected=user.className === classRecord.name)= classRecord.name
              button(type="submit")= "更新班级"

block pageScripts
  +formScripts('profile-password.js', true)
  +pageScript('/assets/profile-class.js')
