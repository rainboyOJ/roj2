//- 管理后台首页：集中展示管理员可用功能入口。
extends layout.pug

block content
  section.list-panel
    header
      hgroup
        h1= "管理后台"
        p.page-lead= "集中进入题目、用户和提交管理，不需要记住各个后台 URL。"
    .feature-grid
      article.feature-card
        h3= "题目管理"
        p= "创建、编辑、发布题目，并维护题面和支持语言。"
        .page-actions
          a(href='/admin/problems' role="button")= "打开题目管理"
          a(href='/admin/problems/new' role="button" class="secondary")= "创建题目"
      article.feature-card
        h3= "用户审核"
        p= "查看注册用户，批量通过或拒绝学生账号。"
        .page-actions
          a(href='/admin/users' role="button")= "打开用户管理"
      article.feature-card
        h3= "提交管理"
        p= "查看全站提交记录，追踪评测状态和最终结果。"
        .page-actions
          a(href='/admin/submissions' role="button")= "打开提交管理"
      article.feature-card
        h3= "语言开关"
        p= "控制整个 OJ 当前允许用户提交的编程语言集合。"
        .page-actions
          a(href='/admin/settings/languages' role="button")= "打开语言设置"
      article.feature-card
        h3= "年级管理"
        p= "维护注册页中学生可以选择的年级范围。"
        .page-actions
          a(href='/admin/grades' role="button")= "打开年级管理"
