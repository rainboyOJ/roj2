{
  "name": "move-to-new-oj",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.base.json",
    "dev:api": "node --experimental-strip-types ./apps/api-server/src/index.ts",
    "dev:dispatcher": "node --experimental-strip-types ./apps/judge-dispatcher/src/index.ts",
    "seed": "node --experimental-strip-types ./apps/api-server/src/seed.ts",
    "import:roj": "node --experimental-strip-types ./scripts/import_roj_problems.ts",
    "rebuild:problem-progress": "node --experimental-strip-types ./scripts/rebuild_user_problem_progress.ts",
    "build:problem-editor": "node --experimental-strip-types ./apps/api-server/scripts/build-problem-editor.ts"
  },
  "devDependencies": {
    "@codemirror/lang-cpp": "^6.0.1",
    "@codemirror/lang-python": "^6.1.8",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.1",
    "@fastify/formbody": "^8.0.2",
    "@fastify/view": "^11.1.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.8.0",
    "@types/pug": "^2.0.10",
    "@types/sanitize-html": "^2.16.1",
    "axios": "^1.16.1",
    "codemirror": "^6.0.1",
    "esbuild": "^0.27.0",
    "fastify": "^5.6.1",
    "mongodb": "^6.21.0",
    "playwright": "^1.60.0",
    "pug": "^3.0.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "zod": "^4.1.12"
  }
}
